# --- Roboflow AI Settings ---
ROBOFLOW_API_KEY=your_api_key_here
ROBOFLOW_API_URL=https://serverless.roboflow.com
ROBOFLOW_MODEL_ID=earthquake-damage-detection-xmfgr/1

# AI Detection Thresholds
AI_CONFIDENCE=0.25
AI_IOU_THRESHOLD=0.4

# --- Map Settings ---
DEFAULT_CITY="Antakya, Hatay, Turkey"

# --- Routing Engine Settings ---
DANGER_RADIUS_BASE=50
DANGER_WEIGHT_MULTIPLIER=100

# --- Server Settings ---
HOST=0.0.0.0
PORT=8000
